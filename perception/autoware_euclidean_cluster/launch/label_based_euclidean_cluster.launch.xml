<launch>
  <arg name="input_pointcloud" default="/perception/ptv3/segmented/pointcloud"/>
  <arg name="output_objects" default="objects"/>
  <arg name="use_pointcloud_container" default="false"/>
  <arg name="pointcloud_container_name" default="pointcloud_container"/>
  <arg name="param_path" default="$(find-pkg-share autoware_euclidean_cluster)/config/label_based_euclidean_cluster.param.yaml"/>
  <arg name="shape_policy" default="0" description="Shape policy for clustering 0: ALL_POLYGON, 1: LABEL_DEPEND"/>
  <include file="$(find-pkg-share autoware_euclidean_cluster)/launch/label_based_euclidean_cluster.launch.py">
    <arg name="input_pointcloud" value="$(var input_pointcloud)"/>
    <arg name="output_objects" value="$(var output_objects)"/>
    <arg name="use_pointcloud_container" value="$(var use_pointcloud_container)"/>
    <arg name="pointcloud_container_name" value="$(var pointcloud_container_name)"/>
    <arg name="param_path" value="$(var param_path)"/>
    <arg name="shape_policy" value="$(var shape_policy)"/>
  </include>
</launch>
